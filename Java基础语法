七、常用算法模板
二分查找
java
int binarySearch(int[] arr, int target) {
    int left = 0, right = arr.length - 1;
    while (left <= right) {
        int mid = left + (right - left) / 2;
        if (arr[mid] == target) return mid;
        if (arr[mid] < target) left = mid + 1;
        else right = mid - 1;
    }
    return -1;
}
快速幂
java
long fastPow(long a, long n) {
    long result = 1;
    while (n > 0) {
        if ((n & 1) == 1) result *= a;
        a *= a;
        n >>= 1;
    }
    return result;
}
最大公约数
java
int gcd(int a, int b) {
    return b == 0 ? a : gcd(b, a % b);
}
最小公倍数
java
int lcm(int a, int b) {
    return a / gcd(a, b) * b;
}
