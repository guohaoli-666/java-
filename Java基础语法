一、基本输入输出
输入模板
java
import java.util.Scanner;
import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        
        // 各种输入方式
        int n = sc.nextInt();
        long l = sc.nextLong();
        double d = sc.nextDouble();
        String s1 = sc.next();      // 单词
        String s2 = sc.nextLine();   // 整行
        char c = sc.next().charAt(0); // 字符
        
        // 多组输入直到EOF
        while (sc.hasNext()) {
            int a = sc.nextInt();
            int b = sc.nextInt();
            System.out.println(a + b);
        }
        
        sc.close();
    }
}
